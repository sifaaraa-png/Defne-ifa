<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if baslik %}{{ baslik }} | {{ site.ad }}{% else %}{{ site.ad }} — {{ site.slogan }}{% endif %}</title>
  <meta name="description" content="{% if aciklama %}{{ aciklama }}{% else %}{{ site.aciklama }}{% endif %}">
  {% if anahtarKelimeler %}<meta name="keywords" content="{{ anahtarKelimeler }}">{% endif %}
  <meta name="author" content="{{ site.yazar }}">
  <meta name="robots" content="{% if noindex %}noindex, follow{% else %}index, follow{% endif %}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:type" content="{% if kategori %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{% if baslik %}{{ baslik }}{% else %}{{ site.ad }}{% endif %}">
  <meta property="og:description" content="{% if aciklama %}{{ aciklama }}{% else %}{{ site.aciklama }}{% endif %}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:locale" content="tr_TR">
  <meta property="og:site_name" content="{{ site.ad }}">
  <meta property="og:image" content="{{ site.url }}{% if kapak %}{{ kapak }}{% else %}/img/og-kapak.jpg{% endif %}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% if baslik %}{{ baslik }}{% else %}{{ site.ad }}{% endif %}">
  <meta name="twitter:description" content="{% if aciklama %}{{ aciklama }}{% else %}{{ site.aciklama }}{% endif %}">
  <meta name="twitter:image" content="{{ site.url }}{% if kapak %}{{ kapak }}{% else %}/img/og-kapak.jpg{% endif %}">

  <link rel="icon" type="image/png" href="/img/favicon.png">
  <link rel="apple-touch-icon" href="/img/favicon.png">
  <link rel="stylesheet" href="/css/style.css">

  {% if kategori %}
  {% set katAdSchema = "" %}
  {% for k in site.kategoriler %}{% if k.slug == kategori %}{% set katAdSchema = k.ad %}{% endif %}{% endfor %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ baslik }}",
    "description": "{{ aciklama }}",
    "image": "{{ site.url }}{% if kapak %}{{ kapak }}{% else %}/img/og-kapak.jpg{% endif %}",
    "datePublished": "{{ page.date | iso }}",
    "dateModified": "{% if guncelleme %}{{ guncelleme | iso }}{% else %}{{ page.date | iso }}{% endif %}",
    "author": { "@type": "Organization", "name": "{{ site.yazar }}", "url": "{{ site.url }}/hakkimizda/" },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.ad }}",
      "logo": { "@type": "ImageObject", "url": "{{ site.url }}/img/logo.png" }
    },
    "mainEntityOfPage": "{{ site.url }}{{ page.url }}"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "{{ site.url }}/" },
      { "@type": "ListItem", "position": 2, "name": "{{ katAdSchema }}", "item": "{{ site.url }}/{{ kategori }}/" },
      { "@type": "ListItem", "position": 3, "name": "{{ baslik }}", "item": "{{ site.url }}{{ page.url }}" }
    ]
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.ad }}",
    "url": "{{ site.url }}",
    "description": "{{ site.aciklama }}"
  }
  </script>
  {% endif %}
</head>
<body>
  <header class="ust">
    <div class="ust-ic">
      <a href="/" class="logo">
        <img src="/img/logo.png" alt="{{ site.ad }} logo" width="42" height="42">
        <span class="logo-yazi">Defne<span>Şifa</span></span>
      </a>
      <button class="menu-ac" aria-label="Menüyü aç" onclick="document.getElementById('anamenu').classList.toggle('acik')">
        <span></span><span></span><span></span>
      </button>
      <ul class="menu" id="anamenu">
        {% for kat in site.kategoriler %}
        <li><a href="/{{ kat.slug }}/">{{ kat.ad }}</a></li>
        {% endfor %}
        <li><a href="/hakkimizda/">Hakkımızda</a></li>
        <li><a href="/iletisim/">İletişim</a></li>
      </ul>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <!-- E-posta bülteni -->
  <section class="bulten">
    <div class="kapsam">
      <div class="bulten-ic">
        <div class="bulten-yazi">
          <h3>Haftalık doğal yaşam önerileri</h3>
          <p>Şifalı bitkiler, sağlıklı tarifler ve doğal yaşam ipuçları her hafta e-postanıza gelsin.</p>
        </div>
        <form name="bulten" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/tesekkurler/" class="bulten-form">
          <input type="hidden" name="form-name" value="bulten">
          <p hidden><label>Doldurmayın: <input name="bot-field"></label></p>
          <input type="email" name="eposta" placeholder="E-posta adresiniz" required aria-label="E-posta adresiniz">
          <button type="submit" class="btn">Abone Ol</button>
        </form>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="kapsam">
      <div class="footer-izgara">
        <div class="footer-tanitim">
          <div class="footer-marka">
            <img src="/img/logo.png" alt="{{ site.ad }} logo" width="52" height="52">
            <div class="footer-logo">Defne<span>Şifa</span></div>
          </div>
          <p>{{ site.aciklama }} İskenderun ve tüm Hatay bölgesine doğal yaşam rehberliği.</p>
          <div class="sosyal-ikonlar">
            {% if site.sosyal.instagram %}<a href="{{ site.sosyal.instagram }}" aria-label="Instagram" target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 3.68a6.16 6.16 0 100 12.32 6.16 6.16 0 000-12.32zM12 16a4 4 0 110-8 4 4 0 010 8zm6.4-10.85a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z"/></svg></a>{% endif %}
            {% if site.sosyal.youtube %}<a href="{{ site.sosyal.youtube }}" aria-label="YouTube" target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2 31 31 0 000 12a31 31 0 00.5 5.8 3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1A31 31 0 0024 12a31 31 0 00-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg></a>{% endif %}
            {% if site.sosyal.pinterest %}<a href="{{ site.sosyal.pinterest }}" aria-label="Pinterest" target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12c0 5.1 3.1 9.4 7.6 11.2-.1-.9-.2-2.4 0-3.4l1.4-5.8s-.3-.7-.3-1.8c0-1.7 1-2.9 2.2-2.9 1 0 1.5.8 1.5 1.7 0 1-.7 2.6-1 4-.3 1.2.6 2.1 1.7 2.1 2 0 3.6-2.2 3.6-5.3 0-2.8-2-4.7-4.8-4.7-3.3 0-5.2 2.4-5.2 5 0 1 .4 2 .8 2.6.1.1.1.2.1.3l-.3 1.2c0 .2-.2.3-.4.2-1.4-.7-2.3-2.7-2.3-4.4 0-3.6 2.6-6.9 7.5-6.9 3.9 0 7 2.8 7 6.5 0 3.9-2.5 7.1-5.9 7.1-1.2 0-2.3-.6-2.6-1.3l-.7 2.7c-.3 1-.9 2.2-1.4 3 1 .3 2.1.5 3.2.5 6.6 0 12-5.4 12-12S18.6 0 12 0z"/></svg></a>{% endif %}
            {% if site.sosyal.facebook %}<a href="{{ site.sosyal.facebook }}" aria-label="Facebook" target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12a12 12 0 10-13.9 11.9v-8.4H7.1V12h3V9.4c0-3 1.8-4.6 4.5-4.6 1.3 0 2.7.2 2.7.2v2.9h-1.5c-1.5 0-2 .9-2 1.9V12h3.3l-.5 3.5h-2.8v8.4A12 12 0 0024 12z"/></svg></a>{% endif %}
          </div>
        </div>
        <div>
          <h4>Kategoriler</h4>
          <ul>
            {% for kat in site.kategoriler %}
            <li><a href="/{{ kat.slug }}/">{{ kat.ad }}</a></li>
            {% endfor %}
          </ul>
        </div>
        <div>
          <h4>Bağlantılar</h4>
          <ul>
            <li><a href="/">Ana Sayfa</a></li>
            <li><a href="/hakkimizda/">Hakkımızda</a></li>
            <li><a href="/iletisim/">İletişim</a></li>
            <li><a href="/gizlilik/">Gizlilik ve KVKK</a></li>
          </ul>
        </div>
        <div>
          <h4>İletişim</h4>
          <ul class="footer-iletisim">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> {{ site.konum }}</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg> <a href="https://wa.me/{{ site.whatsapp }}" rel="nofollow">{{ site.whatsappGorunen }}</a></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg> <a href="mailto:{{ site.eposta }}">{{ site.eposta }}</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-alt">
        <span>© {{ site.yil }} {{ site.ad }} · Tüm hakları saklıdır</span>
        <a href="https://akodijital.com" class="ako-imza" target="_blank" rel="noopener">
          <span class="nokta"></span> Tasarım & geliştirme: <strong>AKO Dijital</strong>
        </a>
      </div>
    </div>
  </footer>

  <a href="https://wa.me/{{ site.whatsapp }}" class="wa-yuzen" aria-label="WhatsApp'tan yazın" rel="nofollow" target="_blank">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.045zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
  </a>
</body>
</html>
